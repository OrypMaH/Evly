<%# app/views/events/_responsible_person_fields.html.erb %>
<div class="item responsible-person-item" data-index="<%= f.index %>">
  <div class="right floated content">
    <%= f.hidden_field :_destroy, class: 'destroy-flag' %>
    <%= f.hidden_field :id if f.object.persisted? %>
    <%= f.hidden_field :user_id, class: 'user-id-field' %>
    <%= f.hidden_field :role_id, class: 'role-id-field' %>
    
    <button type="button" 
            class="ui mini basic red icon button remove-responsible-btn"
            title="Удалить">
      <i class="trash icon"></i>
    </button>
  </div>
  
  <i class="user circle middle aligned icon"></i>
  <div class="content">
    <div class="header">
      <span class="user-name"><%= f.object.user&.full_name || 'Не выбран' %></span>
      <span class="ui tiny label role-name">
        <i class="suitcase icon"></i>
        <%= f.object.role&.name || 'Должность не выбрана' %>
      </span>
    </div>
    <% if f.object.user&.contact.present? %>
      <div class="description">
        <i class="phone icon"></i> <%= f.object.user.contact %>
      </div>
    <% end %>
  </div>
</div>