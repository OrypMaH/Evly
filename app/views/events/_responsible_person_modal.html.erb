<%# app/views/events/_responsible_person_modal.html.erb %>
<div class="ui modal" id="responsible-person-modal">
  <i class="close icon"></i>
  <div class="header">Добавить ответственное лицо</div>
  
  <div class="content">
    <div id="modal-error-message" class="ui error message" style="display: none;"></div>
    
    <div class="ui form">
      <!-- Поиск пользователя -->
      <div class="field">
        <label>Поиск пользователя</label>
        <div class="ui search" id="user-search">
          <div class="ui icon input" style="width: 100%;">
            <input type="text" 
                   id="user-search-input" 
                   class="prompt" 
                   placeholder="Введите имя или email...">
            <i class="search icon"></i>
          </div>
          <div class="results"></div>
        </div>
      </div>
      
      <!-- Выбранный пользователь -->
      <div id="selected-user-info" class="ui segment" style="display: none;">
        <div class="ui grid">
          <div class="twelve wide column">
            <strong>Выбран:</strong> <span id="selected-user-name"></span>
          </div>
          <div class="four wide column right aligned">
            <button type="button" 
                    id="clear-user-selection" 
                    class="ui mini basic button">
              Очистить
            </button>
          </div>
        </div>
      </div>
      
      <!-- Выбор должности -->
      <div id="role-selection-container" style="display: none; margin-top: 15px;">
        <div class="field">
          <label>Должность</label>
          <select id="user-role-select" class="ui dropdown">
            <option value="">Выберите должность</option>
          </select>
        </div>
      </div>
    </div>
  </div>
  
  <div class="actions">
    <button type="button" class="ui black deny button">Отмена</button>
    <button type="button" 
            id="confirm-add-responsible" 
            class="ui primary button" 
            disabled>
      Добавить в форму
    </button>
  </div>
</div>