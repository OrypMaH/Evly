<%# app/views/sessions/new.html.erb %>

<div class="ui middle aligned center aligned grid" style="margin-top: 5em;">
  <div class="six wide column">
    <h2 class="ui teal image header">
      <i class="user circle icon"></i>
      <div class="content">
        Вход в систему
      </div>
    </h2>
    
    <%= form_with url: session_path, class: "ui large form" do |f| %>
      <div class="ui stacked segment">
        <div class="field">
          <div class="ui left icon input">
            <i class="id card icon"></i>
            <%= f.text_field :id, placeholder: "ID пользователя" %>
          </div>
        </div>
        
        <div class="field">
          <div class="ui left icon input">
            <i class="lock icon"></i>
            <%= f.password_field :password, placeholder: "Пароль" %>
          </div>
        </div>
        
        <%= f.submit "Войти", class: "ui fluid large teal submit button" %>
      </div>
      
      <div class="ui error message"></div>
    <% end %>
    
    <div class="ui message">
      Нет аккаунта? <%= link_to "Зарегистрироваться", new_user_path %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbolinks:load', function() {
    $('.ui.form').form({
      fields: {
        id: {
          identifier: 'id',
          rules: [{
            type: 'empty',
            prompt: 'Введите ID пользователя'
          }]
        },
        password: {
          identifier: 'password',
          rules: [{
            type: 'empty',
            prompt: 'Введите пароль'
          }]
        }
      }
    });
  });
</script>