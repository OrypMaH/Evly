<%# app/views/plans/_bulk_add_modal.html.erb %>
<div class="ui modal" id="bulkAddToPlanModal">
  <i class="close icon"></i>
  <div class="header">Добавить выбранные мероприятия в план</div>
  
  <div class="content">
    <div id="modalError" style="display: none;"></div>
    
    <div class="ui form">
      <div class="field">
        <label>Выбрано мероприятий:</label>
        <div class="ui blue horizontal label" id="selectedEventsCount">0</div>
      </div>
      
      <div id="selectedEventsList" class="ui relaxed list" style="max-height: 150px; overflow-y: auto; margin-bottom: 20px; display: none;">
      </div>
      
      <div id="periodInfo" style="display: none;"></div>
      
      <div class="field">
        <label>Выберите план:</label>
        <select class="ui dropdown" id="planSelect" name="plan_id">
          <option value="">Загрузка планов...</option>
        </select>
      </div>
      
      <div class="field">
        <label>Информация о плане:</label>
        <div id="planInfo" class="ui segment" style="display: none;">
          <div class="ui list">
            <div class="item">
              <i class="file alternate icon"></i>
              <div class="content">
                <div class="header" id="planTitle"></div>
                <div class="description" id="planPeriod"></div>
              </div>
            </div>
            <div class="item">
              <i class="calendar check icon"></i>
              <div class="content">
                <div class="description">
                  Мероприятий в плане: <span id="planEventsCount">0</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="actions">
    <div class="ui black deny button">Отмена</div>
    <button id="confirmBulkAdd" class="ui primary button" disabled>
      <i class="plus icon"></i> Добавить в план
    </button>
  </div>
</div>