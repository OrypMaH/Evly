<%= form_with model: [@department,plan], local: true, class: "ui form" do |form| %>
  <% if plan.errors.any? %>
    <div class="ui error message">
      <ul>
        <% plan.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%= form.hidden_field :department_id, value: params[:department_id] %>
  <div class="field">
    <%= form.label :title, "Название плана" %>
    <%= form.text_field :title, placeholder: "Например: План работы на январь 2024" %>
  </div>
  
  <div class="field">
    <%= form.label :description, "Описание плана" %>
    <%= form.text_area :description, rows: 4, placeholder: "Краткое описание целей и задач плана" %>
  </div>
  
  <div class="two fields">
    <div class="field">
      <%= form.label :start_date, "Начало периода" %>
      <%= form.date_field :start_date, 
            value: plan.start_date || Date.current %>
    </div>
    
    <div class="field">
      <%= form.label :end_date, "Окончание периода" %>
      <%= form.date_field :end_date, 
            value: plan.end_date || Date.current + 1.month,
            min: plan.start_date || Date.current %>
    </div>
  </div>
  
  <div class="field">
    <div class="ui message">
      <div class="header">Информация</div>
      <p>
        План создается для подразделения: <strong><%= current_user.current_department.name %></strong><br>
        Создатель: <strong><%= current_user.full_name %></strong>
      </p>
    </div>
  </div>
  
  <%= form.submit "Сохранить план", class: "ui primary button" %>
  <%= link_to "Отмена", department_plans_path(@department), class: "ui button" %>
<% end %>