<div class="ui segment" style="padding: 0; overflow-x: auto;">
  <table class="ui small compact celled table">
    <thead>
      <tr>
        <th class="center aligned">ID</th>
        <th>Название</th>
        <th>ООВО</th>
        <th>Уровень</th>
        <th>Формат</th>
        <th>Направление</th>
        <th class="center aligned">Период проведения</th>
        <th>Статусы подразделений</th>
        <th class="center aligned">Участники</th>
        <th class="center aligned">Ответственные</th>
        <th class="center aligned">Действия</th>
      </tr>
    </thead>
    
    <tbody>
      <% events.each do |event| %>
        <tr>
          <td class="center aligned"><%= event.id %></td>
          <td class="title-column"><div class="title-text"><%= event.title %></div></td>
          <td><%= event.educational_organization.name %></td>
          <td><span class="ui tiny label level-<%= event.level.name.parameterize %>"><%= event.level.name %></span></td>
          <td><%= event.format %></td>
          <td><%= link_to_direction(event.direction, format_direction(event.direction)) %></td>
          <td class="center aligned"><%= format_event_period(event.start_date, event.end_date) %></td>
          <td>
            <div class="ui mini labels">
              <% event.event_departments.each do |ed| %>
                <div class="ui <%= ed.status %> label"><%= link_to_department(ed.department) %></div>
              <% end %>
            </div>
          </td>
          <td class="center aligned"><div class="ui teal circular mini label"><%= event.people %></div></td>
          <td class="center aligned"><%= render_responsible_labels(event) %></td>
          <td class="center aligned"><%= render_event_buttons(event) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>