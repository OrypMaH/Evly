<div class="ui container">
  <div class="ui segment">
    <h1 class="ui header">
      <i class="users icon"></i>
      Управление ролями пользователей
    </h1>
  </div>

  <div class="ui segment">
    <table class="ui striped table">
      <thead>
        <tr>
          <th>Пользователь</th>
          <th>Назначенные роли</th>
          <th>Текущая роль</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td>
              <strong><%= link_to_user(user) %></strong>
            </td>
            <td>
              <div class="ui horizontal list">
                <% @user_department_roles[user.id].each do |role| %>
                  <div class="item">
                    <div class="ui tiny basic label">
                      <%= role.name %>
                    </div>
                  </div>
                <% end %>
              </div>
            </td>
            <td>
              <% if user.current_role %>
                <span class="ui small green label"><%= user.current_role.name %></span>
              <% else %>
                <span class="ui tiny text muted">Не выбрана</span>
              <% end %>
            </td>
            <td>
              <%= link_to department_user_edit_roles_path(user.current_department, user), class: 'ui small primary button' do %>
                <i class="edit icon"></i>
                Назначить роли
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= link_to 'Назад', root_path, class: 'ui button' %>
</div>